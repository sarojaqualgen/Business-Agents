ANTHROPIC_API_KEY=your_key_here
FAP_JWT_SECRET=change_this_to_a_strong_secret_in_production

# MinIO — document storage (S3-compatible)
# Local dev: docker run -p 9000:9000 -p 9001:9001 minio/minio server /data --console-address ":9001"
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=aldergate-docs
MINIO_SECURE=false
