ANTHROPIC_API_KEY=your_key_here
FAP_JWT_SECRET=change_this_to_a_strong_secret_in_production

# PostgreSQL — primary database (Phase 6)
# Run: docker run -d --name aldergate-pg -e POSTGRES_PASSWORD=postgres -p 5432:5432 postgres:16
# Then create the DB: psql -h localhost -U postgres -c "CREATE DATABASE aldergate;"
# Then run migrations: alembic upgrade head
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aldergate

# MinIO — document storage (S3-compatible, optional)
# Local dev: docker run -d --name aldergate-minio -p 9000:9000 -p 9001:9001 minio/minio server /data --console-address ":9001"
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=aldergate-docs
MINIO_SECURE=false
