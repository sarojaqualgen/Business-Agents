# Base URL the API client talks to when it does hit a real backend.
# Unused in development by default — see VITE_USE_MOCK_API below.
VITE_API_BASE_URL=/api

# Development (`npm run dev`) uses the mock API client automatically and
# needs no backend running — this is the default with no .env file present.
# Set to "false" here to opt back into calling a real local backend during
# development once api/main.py (Phase 4) exists.
#
# In production builds this flips the other way: set to "true" to force
# mock data instead of a real backend.
VITE_USE_MOCK_API=false

# Only used when VITE_USE_MOCK_API=false in development. Set to "true" to
# re-enable the Vite dev proxy at /api -> VITE_API_PROXY_TARGET.
VITE_ENABLE_BACKEND_PROXY=false
VITE_API_PROXY_TARGET=http://localhost:8000
